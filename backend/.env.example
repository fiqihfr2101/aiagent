# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (if using Claude models - Recommended for Hermes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter API Key (alternative for access to 300+ models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Temporal Server Address
TEMPORAL_ADDRESS=localhost:7233

# Database URLs
DATABASE_URL=postgresql://temporal:***@localhost:5432/hermes
REPLICA_DB_URL=postgresql://replicator:***@localhost:5434/hermes

# Agent Working Directory - Where agents create and save projects
# On Windows use absolute paths: C:\Users\username\Documents\Projects
# On Linux/Mac use absolute paths: /home/username/projects
AGENT_WORK_DIR=C:\Users\qoinj\Documents\Fiqih\Project
